<style>
.show-wrap { max-width: 780px; margin: 2rem auto; font-family: 'Segoe UI', sans-serif; }
.show-header { margin-bottom: 1rem; }
.show-title { font-size: 24px; font-weight: 700; margin: 0 0 6px; color: #1a1a2e; }
.show-location { font-size: 14px; color: #888; margin: 0; }
