</a>

<div class="show-wrap">

  <div class="show-header">
    <h1 class="show-title"><%= listing.title %></h1>
    <p class="show-location">📍 <%= listing.location %>, <%= listing.country %></p>
  </div>

  <div class="show-img-wrap">
    <img src="<%= listing.image.url %>" alt="listing image"
         onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1571896349842-33c89424de2d?auto=format&fit=crop&w=800&q=60';">
</div>

  <div class="show-body">
    <div class="show-desc-box">
      <div class="owner-badge">
        <span class="owner-icon">🏡</span>
        <div class="owner-info">
          <span class="owner-label">Hosted By</span>
          <span class="owner-name"><%= listing.owner.username %></span>
        </div>
      </div>
      <p class="show-desc-label"><b>About this place</b></p>
      <p class="show-desc-text"><%= listing.description %></p>
    </div>

    <div>
      <div class="show-info-box">
        <div class="show-info-row">
          <span class="show-info-label">Location</span>
          <span class="show-info-value"><%= listing.location %></span>
        </div>
        <div class="show-info-row">
          <span class="show-info-label">Country</span>
          <span class="show-info-value"><%= listing.country %></span>
        </div>
        <div class="show-price-big">
          &#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "0" %>
        </div>
        <div class="show-price-night"></div>
      </div>

      <%# --- Not logged in --- %>
      <% if (!currUser) { %>
        <a href="/login" class="btn-login-reserve">🔐 Login to Reserve</a>

      <%# --- Logged in as owner --- %>
      <% } else if (currUser._id.equals(listing.owner._id)) { %>
        <div class="show-actions">
          <a href="/listings/<%= listing._id %>/edit" class="btn-edit-s">✏️ Edit</a>
          <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" style="flex:1;">
            <button class="btn-delete-s">🗑 Delete</button>
          </form>
        </div>

      <%# --- Logged in as guest --- %>
     <%# --- Logged in as guest --- %>
    <% } else { %>
      <% if (existingBooking) { %>
        <div class="btn-reserve" style="background: #28a745; cursor: default; text-align:center;">
          ✅ You've Booked This Place
        </div>
      <% } else { %>
        <form method="POST" action="/listings/<%= listing._id %>/reserve">
          <button type="submit" class="btn-reserve">🗓 Reserve this Place</button>
        </form>
      <% } %>
    <% } %>
    </div> 
  </div>


  <hr>

<div class="map-section">
  <h3 class="map-title">📍 Where you'll be</h3>
  <p class="map-subtitle"><%= listing.location %>, <%= listing.country %></p>
  <div id="map"></div>
</div>

  <div class="reviews-section">
  

    <h2 class="reviews-title">⭐ Reviews</h2>

<!-- Analyze Reviews button aur result box -->
<button id="analyzeBtn" data-listing-id="<%= listing._id %>" class="btn-review-submit" style="margin-bottom: 1rem;">
  🔍 Analyze Reviews
</button>

<p id="loadingText" style="display:none; color:#888; font-size:14px; margin-bottom:1rem;">
  Analyzing reviews...
</p>

<div id="sentimentBox" class="sentiment-box" style="display:none;">
  <span class="sentiment-emoji" id="sentimentEmoji"></span>
  <div class="sentiment-content">
    <p class="sentiment-label" id="sentimentLabel"></p>
    <p class="sentiment-summary" id="sentimentSummary"></p>
  </div>
</div>


    <% if(currUser) { %>
      <div class="review-form-box">
        <h5>Leave a Review</h5>
        <form method="POST" action="/listings/<%= listing._id %>/reviews" class="needs-validation" novalidate>
          <label class="review-field-label">Your Rating</label>
          <div class="star-input-wrap">
            <input type="radio" id="star5" name="review[rating]" value="5" required>
            <label for="star5">★</label>
            <input type="radio" id="star4" name="review[rating]" value="4">
            <label for="star4">★</label>
            <input type="radio" id="star3" name="review[rating]" value="3">
            <label for="star3">★</label>
            <input type="radio" id="star2" name="review[rating]" value="2">
            <label for="star2">★</label>
            <input type="radio" id="star1" name="review[rating]" value="1">
            <label for="star1">★</label>
          </div>

          <label class="review-field-label" for="comment">Your Comment</label>
          <textarea
            name="review[comment]"
            id="comment"
            class="review-textarea"
            rows="3"
            placeholder="Share your experience about this place..."
            required
            minlength="5"
          ></textarea>
          <div class="invalid-feedback" style="font-size: 12px;">
            Oops! Please write a bit more about your experience.
          </div>
          <button type="submit" class="btn-review-submit">Submit Review</button>
        </form>
      </div>
    <% } else { %>
      <div class="review-login-prompt">
        <p>✍️ Want to share your experience?</p>
        <a href="/login" class="btn-login-reserve">🔐 Login to Review</a>
      </div>
    <% } %>

    <hr>

    <% if (listing.reviews && listing.reviews.length > 0) { %>
      <div class="reviews-list">
        <% for (let review of listing.reviews) { %>
          <div class="review-card">
            <div class="review-card-top">
              <div class="review-card-left">
                <div class="review-author">
                  <div class="review-author-avatar">
                    <%= review.author.username.charAt(0).toUpperCase() %>
                  </div>
                  <span class="review-author-name"><%= review.author.username %></span>
                </div>
                <span class="review-divider">|</span>
                <div class="review-stars">
                  <% for (let i = 1; i <= 5; i++) { %>
                    <% if (i <= review.rating) { %>★<% } else { %><span class="empty">★</span><% } %>
                  <% } %>
                </div>
              </div>
              <span class="review-date">
                <%= new Date(review.createdAt).toLocaleDateString("en-IN", {
                  day: "numeric", month: "short", year: "numeric"
                }) %>
              </span>
            </div>

            <p class="review-comment"><%= review.comment %></p>

            <% if (currUser && review.author._id.equals(currUser._id)) { %>
              <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                <button class="btn btn-danger btn-sm">Delete</button>
              </form>
            <% } %>
          </div>
        <% } %>
      </div>
    <% } else { %>
      <p class="no-reviews">No reviews yet. Be the first to review this place! 🌟</p>
    <% } %>
  </div>

</div>

<script src="/js/map.js"></script>

<script>
document.getElementById("analyzeBtn").addEventListener("click", async function () {
    const listingId = this.dataset.listingId;
    const loadingText = document.getElementById("loadingText");
    const sentimentBox = document.getElementById("sentimentBox");
    const btn = this;

    // Button disable karna taaki user baar baar click na kare
    btn.disabled = true;
    loadingText.style.display = "block";
    sentimentBox.style.display = "none";

    try {
        const res = await fetch(`/listings/${listingId}/analyze-reviews`, {
            method: "POST"
        });
        const data = await res.json();

        loadingText.style.display = "none";
        btn.disabled = false;

        if (!data.hasReviews) {
            sentimentBox.className = "sentiment-box neutral";
            document.getElementById("sentimentEmoji").innerText = "💬";
            document.getElementById("sentimentLabel").innerText = "No Reviews Yet";
            document.getElementById("sentimentSummary").innerText = "Abhi tak koi review nahi hai is listing pe.";
            sentimentBox.style.display = "flex";
            return;
        }

        // Kaunsa sentiment sabse zyada hai, uske hisaab se color/emoji decide karna
        const { positive, neutral, negative, summary, averageRating } = data;
        let type = "neutral";
        let emoji = "😐";

        if (positive > neutral && positive > negative) {
            type = "positive";
            emoji = "😊";
        } else if (negative > positive && negative > neutral) {
            type = "negative";
            emoji = "😞";
        } else if (positive > 0 && negative > 0) {
            type = "mixed";
            emoji = "🤔";
        }

        sentimentBox.className = `sentiment-box ${type}`;
        document.getElementById("sentimentEmoji").innerText = emoji;
        document.getElementById("sentimentLabel").innerText = `Average Rating: ${averageRating} ⭐`;
        document.getElementById("sentimentSummary").innerText = summary;
        sentimentBox.style.display = "flex";

    } catch (err) {
        loadingText.style.display = "none";
        btn.disabled = false;
        alert("Kuch gadbad ho gayi, dobara try kar.");
        console.error(err);
    }
});
</script>
