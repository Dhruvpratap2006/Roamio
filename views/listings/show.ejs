.show-img-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; }
.show-body { display: grid; grid-template-columns: 1fr 260px; gap: 1.5rem; align-items: start; }
.show-desc-box { background: #f9f9f9; border-radius: 14px; padding: 1.25rem; }
.show-desc-label { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: #0c0000f8; margin: 0 0 8px; }
