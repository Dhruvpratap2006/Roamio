<% layout("/layouts/boilerplate") %>
<% locals.bodyClass = "page-auth" %>

<div class="signup-split">
  <div class="login-left">
    <div class="left-tag"><h2>welcome back</h2></div>
    <h1 class="left-headline">Good to see<br>you again.</h1>
    <p class="left-sub">Your next adventure is just a login away.</p>
    <div class="left-stats">
      <div><span class="stat-num">12k+</span><span class="stat-label">listings</span></div>
      <div><span class="stat-num">80+</span><span class="stat-label">countries</span></div>
    </div>
  </div>
  <div class="signup-right">
    <div class="auth-brand mb-4">
    <a href="/listings" class="text-decoration-none">
      <i class="bi bi-compass"></i>
      <span>Roamio</span>
    </a>
  </div>
    <h2>Log In</h2>
    <p class="text-muted">Welcome back! Please enter your details.</p>
    <form method="POST" action="/login" class="needs-validation" novalidate>
      <div class="mb-3">
        <label for="username" class="form-label">Username</label>
        <input type="text" name="username" id="username" class="form-control roamio-input" placeholder="Enter your username" required>
        <div class="invalid-feedback">Please provide your username.</div>
      </div>
      <div class="mb-3">
        <label for="password" class="form-label">Password</label>
        <input type="password" name="password" id="password" class="form-control roamio-input" placeholder="Enter your password" required>
        <div class="invalid-feedback">Please provide your password.</div>
      </div>
      <button type="submit" class="btn roamio-btn w-100">Log In →</button>
    </form>
    <p class="text-center mt-3 text-muted" style="font-size:13px;">
      Don't have an account? <a href="/signUp" class="roamio-link">Sign Up</a>
    </p>
  </div>
</div>